{
  "name": "Debt",
  "type": "object",
  "properties": {
    "customer_id": {
      "type": "string",
      "description": "\u05de\u05d6\u05d4\u05d4 \u05dc\u05e7\u05d5\u05d7"
    },
    "customer_name": {
      "type": "string",
      "description": "\u05e9\u05dd \u05d4\u05dc\u05e7\u05d5\u05d7"
    },
    "order_id": {
      "type": "string",
      "description": "\u05de\u05d6\u05d4\u05d4 \u05d4\u05d6\u05de\u05e0\u05d4 \u05de\u05de\u05e0\u05d4 \u05e0\u05d5\u05e6\u05e8 \u05d4\u05d7\u05d5\u05d1"
    },
    "order_number": {
      "type": "string",
      "description": "\u05de\u05e1\u05e4\u05e8 \u05d4\u05d6\u05de\u05e0\u05d4"
    },
    "amount": {
      "type": "number",
      "description": "\u05e1\u05db\u05d5\u05dd \u05d4\u05d7\u05d5\u05d1 \u05d4\u05de\u05e7\u05d5\u05e8\u05d9"
    },
    "amount_paid": {
      "type": "number",
      "default": 0,
      "description": "\u05d4\u05e1\u05db\u05d5\u05dd \u05e9\u05e9\u05d5\u05dc\u05dd \u05e2\u05d3 \u05db\u05d4"
    },
    "balance_due": {
      "type": "number",
      "description": "\u05d9\u05ea\u05e8\u05ea \u05d4\u05d7\u05d5\u05d1 \u05dc\u05ea\u05e9\u05dc\u05d5\u05dd"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "partially_paid",
        "paid",
        "overdue"
      ],
      "default": "open",
      "description": "\u05e1\u05d8\u05d8\u05d5\u05e1 \u05d4\u05d7\u05d5\u05d1"
    },
    "due_date": {
      "type": "string",
      "format": "date",
      "description": "\u05ea\u05d0\u05e8\u05d9\u05da \u05d9\u05e2\u05d3 \u05dc\u05ea\u05e9\u05dc\u05d5\u05dd"
    },
    "notes": {
      "type": "string",
      "description": "\u05d4\u05e2\u05e8\u05d5\u05ea"
    }
  },
  "required": [
    "customer_id",
    "customer_name",
    "amount",
    "balance_due"
  ]
}