    "is_wholesale": {
      "type": "boolean",
      "default": false,
      "description": "\u05d4\u05d0\u05dd \u05d6\u05d5 \u05e7\u05d1\u05d5\u05e6\u05ea \u05e1\u05d9\u05d8\u05d5\u05e0\u05d0\u05d9\u05dd - \u05d4\u05de\u05d7\u05d9\u05e8 \u05d9\u05d7\u05d5\u05e9\u05d1 \u05db-50% \u05de\u05de\u05d7\u05d9\u05e8 \u05d4\u05e6\u05e8\u05db\u05df \u05dc\u05e4\u05e0\u05d9 \u05de\u05e2\"\u05de"
