{
  "name": "Product",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "\u05e9\u05dd \u05d4\u05e4\u05e8\u05d9\u05d8"
    },
    "sku": {
      "type": "string",
      "description": "\u05de\u05e7\"\u05d8"
    },
    "category": {
      "type": "string",
      "description": "\u05e7\u05d8\u05d2\u05d5\u05e8\u05d9\u05d4"
    },
    "subcategory": {
      "type": "string",
      "description": "\u05ea\u05ea-\u05e7\u05d8\u05d2\u05d5\u05e8\u05d9\u05d4"
    },
    "product_type": {
      "type": "string",
      "enum": [
        "single",
        "display"
      ],
      "default": "single",
      "description": "\u05e1\u05d5\u05d2 \u05d4\u05e4\u05e8\u05d9\u05d8 - \u05d9\u05d7\u05d9\u05d3 \u05d0\u05d5 \u05d3\u05d9\u05e1\u05e4\u05dc\u05d9\u05d9"
    },
    "price": {
      "type": "number",
      "description": "\u05de\u05d7\u05d9\u05e8 \u05d1\u05e1\u05d9\u05e1"
    },
    "group_prices": {
      "type": "array",
      "description": "\u05de\u05d7\u05d9\u05e8\u05d9\u05dd \u05dc\u05e4\u05d9 \u05e7\u05d1\u05d5\u05e6\u05d4",
      "items": {
        "type": "object",
        "properties": {
          "price_group_id": {
            "type": "string"
          },
          "price_group_name": {
            "type": "string"
          },
          "price": {
            "type": "number"
          }
        }
      }
    },
    "unit": {
      "type": "string",
      "description": "\u05d9\u05d7\u05d9\u05d3\u05ea \u05de\u05d9\u05d3\u05d4 (\u05d9\u05d7', \u05e7\u05d2', \u05dc\u05d9\u05d8\u05e8...)"
    },
    "stock": {
      "type": "number",
      "description": "\u05db\u05de\u05d5\u05ea \u05d1\u05de\u05dc\u05d0\u05d9"
    },
    "image_url": {
      "type": "string",
      "description": "\u05ea\u05de\u05d5\u05e0\u05ea \u05d4\u05e4\u05e8\u05d9\u05d8 \u05d4\u05e8\u05d0\u05e9\u05d9\u05ea"
    },
    "image_urls": {
      "type": "array",
      "description": "\u05ea\u05de\u05d5\u05e0\u05d5\u05ea \u05e0\u05d5\u05e1\u05e4\u05d5\u05ea \u05e9\u05dc \u05d4\u05e4\u05e8\u05d9\u05d8",
      "items": {
        "type": "string"
      }
    },
    "description": {
      "type": "string",
      "description": "\u05ea\u05d9\u05d0\u05d5\u05e8 \u05d4\u05e4\u05e8\u05d9\u05d8"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "\u05d4\u05d0\u05dd \u05d4\u05e4\u05e8\u05d9\u05d8 \u05e4\u05e2\u05d9\u05dc"
    }
  },
  "required": [
    "name",
    "price"
  ]
}