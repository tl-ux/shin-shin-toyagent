{
  "name": "Customer",
  "type": "object",
  "properties": {
    "customer_number": {
      "type": "string",
      "description": "\u05de\u05e1\u05e4\u05e8 \u05dc\u05e7\u05d5\u05d7"
    },
    "name": {
      "type": "string",
      "description": "\u05e9\u05dd \u05d4\u05dc\u05e7\u05d5\u05d7 / \u05e2\u05e1\u05e7"
    },
    "contact_name": {
      "type": "string",
      "description": "\u05e9\u05dd \u05d0\u05d9\u05e9 \u05e7\u05e9\u05e8"
    },
    "phone": {
      "type": "string",
      "description": "\u05d8\u05dc\u05e4\u05d5\u05df"
    },
    "address": {
      "type": "string",
      "description": "\u05db\u05ea\u05d5\u05d1\u05ea"
    },
    "city": {
      "type": "string",
      "description": "\u05e2\u05d9\u05e8"
    },
    "notes": {
      "type": "string",
      "description": "\u05d4\u05e2\u05e8\u05d5\u05ea"
    },
    "is_wholesale": {
      "type": "boolean",
      "default": false,
      "description": "\u05d4\u05d0\u05dd \u05dc\u05e7\u05d5\u05d7 \u05e1\u05d9\u05d8\u05d5\u05e0\u05d0\u05d9 \u2014 \u05d4\u05de\u05d7\u05d9\u05e8 \u05d9\u05d7\u05d5\u05e9\u05d1 \u05db-50% \u05de\u05de\u05d7\u05d9\u05e8 \u05d4\u05e6\u05e8\u05db\u05df \u05dc\u05e4\u05e0\u05d9 \u05de\u05e2\"\u05de"
    },
    "network_commission_percent": {
      "type": "number",
      "description": "\u05d0\u05d7\u05d5\u05d6 \u05e2\u05de\u05dc\u05ea \u05e8\u05e9\u05ea (\u05dc\u05d3\u05d5\u05d2\u05de\u05d4: 10 \u05e2\u05d1\u05d5\u05e8 10%) \u2014 \u05d9\u05ea\u05d5\u05d5\u05e1\u05e3 \u05de\u05e2\u05dc \u05dc\u05de\u05d7\u05d9\u05e8 \u05d4\u05e1\u05d9\u05d8\u05d5\u05e0\u05d0\u05d9 \u05e0\u05d8\u05d5"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "name"
  ]
}